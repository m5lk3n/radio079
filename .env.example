# OpenAI-compatible API for weather text generation
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE_URL=your-api-base-url-here
OPENAI_MODEL=your-llm-here

# Cartesia text-to-speech (see https://docs.cartesia.ai/build-with-cartesia/tts-models/latest)
TTS_API_KEY=your-api-key-here
TTS_API_URL=https://api.cartesia.ai/tts/bytes
TTS_API_VERSION=2026-03-01
TTS_MODEL_ID=sonic-3.5

# Weather location and timezone
WEATHER_LOCATION_LAT=your-latitude-here
WEATHER_LOCATION_LON=your-longitude-here
WEATHER_LOCATION_ALIAS=your-location-alias
WEATHER_TIMEZONE=your-timezone
# timezone examples: "America/New_York", "Europe/London", "Asia/Tokyo"
